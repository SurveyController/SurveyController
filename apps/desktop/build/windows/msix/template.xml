<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="desktopui.exe"
        Arguments=""
        InstallLocation="C:\Program Files\HungryM0\SurveyController">
    </Installer>
    <PackageInformation
        PackageName="SurveyController"
        PackageDisplayName="SurveyController"
        PublisherName="CN=HungryM0"
        PublisherDisplayName="HungryM0"
        Version="5.0.0.0"
        PackageDescription="SurveyController Desktop UI">
        <Capabilities>
            <Capability Name="runFullTrust" />

        </Capabilities>
        <Applications>
            <Application
                Id="com.hungrym0.surveycontroller"
                Description="SurveyController Desktop UI"
                DisplayName="SurveyController"
                ExecutableName="desktopui.exe"
                EntryPoint="Windows.FullTrustApplication">

            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>SurveyController</DisplayName>
            <PublisherDisplayName>HungryM0</PublisherDisplayName>
            <Description>SurveyController Desktop UI</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="desktopui.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
